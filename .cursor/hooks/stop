#!/usr/bin/env node

const { spawn } = require("node:child_process");
const path = require("node:path");

function runProcess(cmd, args, { cwd }) {
  return new Promise((resolve) => {
    const child = spawn(cmd, args, {
      cwd,
      stdio: ["ignore", "pipe", "pipe"],
      env: process.env,
    });

    let out = "";
    child.stdout.setEncoding("utf8");
    child.stderr.setEncoding("utf8");
    child.stdout.on("data", (chunk) => {
      out += chunk;
    });
    child.stderr.on("data", (chunk) => {
      out += chunk;
    });

    child.on("close", (code, signal) => {
      resolve({ ok: code === 0, output: out, code, signal });
    });
    child.on("error", (err) => {
      resolve({ ok: false, output: String(err), code: 1, signal: null });
    });
  });
}

function deny(command,reason) {
  const payload = {
    continue: true,
    permission: "deny",
    user_message: `Command '${command}' failed`,
    agent_message: `Command '${command}' failed: ${reason}`,
  };
  process.stdout.write(JSON.stringify(payload));
}

async function main() {
  const projectDir = process.env.CURSOR_PROJECT_DIR ?? process.cwd();
  const vdomDir = path.join(projectDir, "vdom");

  const commands = [
    {
      cmd: "lamdera",
      args: ["make", "--optimize", "elm/Main.elm", "--output=/dev/null"],
    },
    {
      cmd: "elm-test",
      args: ["--compiler=lamdera"],
    },
  ];

  for (const { cmd, args } of commands) {
    const res = await runProcess(cmd, args, { cwd: vdomDir });
    if (!res.ok) {
      deny(joinCmd(cmd,args),res.output);
      process.exit(2);
    }
  }
}

(async () => {
  await main();
})().catch((err) => {
  deny("STOP_HOOK",String(err?.stack || err));
  process.exit(2);
});

function joinCmd(cmd,args) {
  return `${cmd} ${args.join(" ")}`;
}